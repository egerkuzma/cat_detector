# IP camera that serves a JPEG over HTTP
CAMERA_URL=http://192.0.2.10/IMAGE.JPG
CAMERA_USER=admin
CAMERA_PASSWORD=

# Telegram bot — create via @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Filesystem paths
SAVE_DIR=/home/pi/cam
MODEL_PATH=/home/pi/detect.tflite
LABELS_PATH=/home/pi/coco_labels.txt

# Hardware (BCM pin numbers, comma-separated)
LED_PINS=18,23,24
PWM_DUTY_CYCLE=50

# Behaviour
BRIGHTNESS_THRESHOLD=30
NIGHT_START_HOUR=22
NIGHT_END_HOUR=6
NOTIFICATION_INTERVAL=30
LIGHT_ON_DURATION=60
LIGHT_ON_CAT_HERE=60
DETECTION_THRESHOLD=0.5
POLL_INTERVAL_S=1
HTTP_TIMEOUT_S=5
